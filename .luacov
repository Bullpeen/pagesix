-- LuaCov configuration. Run `busted --coverage` then `luacov`; the report is
-- written to luacov.report.out.
return {
	statsfile = "luacov.stats.out",
	reportfile = "luacov.report.out",

	-- Only measure our own application code.
	include = {
		"^app/app$",
		"^app/migrations$",
		"^app/helpers$",
		"^app/src/",
	},
	exclude = {
		"^app/spec/",
		"^app/static/",
		-- api.lua is ~150 disabled stub endpoints (deferred to a future phase,
		-- not wired into app.lua), so it isn't meaningful coverage.
		"^app/src/api$",
		"luacov",
		"busted",
		"lapis",
		"etlua",
	},
}
