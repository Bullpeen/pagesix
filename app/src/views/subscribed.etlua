
<% if subreddits ~= nil then
    for sub in pairs(subreddits) do 
        require 'pl.pretty'.dump(sub)
        render('views.fragments.subreddit_listing',
            {
                name = sub.name,
                description = sub.description,
                subscribers = sub.subscribers
            })
    end %>
<% else %>
    Nothing
<% end %>