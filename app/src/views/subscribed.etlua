<% if subreddits ~= nil and #subreddits > 0 then
    for _, sub in ipairs(subreddits) do
        render('views.fragments.subreddit_listing', {
            name = sub.name,
            description = sub.description,
            subscribers = sub.subscribers,
        })
    end %>
<% else %>
    <p class="empty">You have no subscriptions yet.</p>
<% end %>
