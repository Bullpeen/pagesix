<%
	local providers = require("lapis.config").get().oauth or {}
	local names = {}
	for name in pairs(providers) do
		names[#names + 1] = name
	end
	table.sort(names)
%>
<% if #names > 0 then %>
<div data-oauth>
	<span data-muted>or</span>
	<% for _, name in ipairs(names) do %>
		<a href="/auth/<%= name %>">Sign in with <%= name %></a>
	<% end %>
</div>
<% end %>
