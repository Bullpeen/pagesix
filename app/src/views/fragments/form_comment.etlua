<% if post_id then %>
	<% if current_user then %>
	<form data-form method="POST" action="/post/<%= post_id %>/comment">
		<input type="hidden" name="csrf_token" value="<%= csrf_token %>">
		<textarea name="body" rows="4" placeholder="What are your thoughts?" required></textarea>
		<div><button data-primary type="submit">Comment</button></div>
	</form>
	<% else %>
	<p data-muted><a href="/login">Log in</a> to leave a comment.</p>
	<% end %>
<% end %>
