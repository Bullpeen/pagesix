<% if post_id then %>
    <form class="comment-form" method="POST" action="/post/<%= post_id %>/comment">
        <input type="hidden" name="csrf_token" value="<%= csrf_token %>">
        <textarea name="body" rows="4" placeholder="What are your thoughts?" required></textarea>
        <button class="button" type="submit">Comment</button>
    </form>
<% end %>
