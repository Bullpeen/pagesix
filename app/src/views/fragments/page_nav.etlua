<% if pagination and (pagination.has_prev or pagination.has_next) then %>
	<nav data-pagination>
		<% if pagination.has_prev then %>
			<a href="?page=<%= pagination.page - 1 %>" rel="prev">&lsaquo; prev</a>
		<% end %>
		<span>page <%= pagination.page %></span>
		<% if pagination.has_next then %>
			<a href="?page=<%= pagination.page + 1 %>" rel="next">next &rsaquo;</a>
		<% end %>
	</nav>
<% end %>
