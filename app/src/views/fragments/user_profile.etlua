<div data-head>
	<h1>User Profile for <%= user_name %></h1>
</div>
<p data-muted><%= karma %> karma</p>
<% if trust_level then %>
<p>Reputation <%= reputation %> <span data-trust><%= trust_level %></span></p>
<% end %>
<% if created_at then %><p data-muted>User since <%= created_at %>.</p><% end %>
